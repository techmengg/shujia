generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String               @id @default(cuid())
  email                  String               @unique
  name                   String?
  password               String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  avatarUrl              String?
  bio                    String?
  bannerUrl              String?
  profileColor           String?
  favoriteMangaIds       String[]             @default([])
  timezone               String               @default("UTC")
  marketingEmails        Boolean              @default(true)
  productUpdates         Boolean              @default(true)
  weeklyDigestEmails     Boolean              @default(true)
  username               String               @unique
  googleId               String?              @unique
  twoFactorEnabled       Boolean              @default(false)
  twoFactorSecret        String?
  twoFactorTempSecret    String?
  twoFactorRecoveryCodes String[]             @default([])
  passwordResetTokens    PasswordResetToken[]
  readingListEntries     ReadingListEntry[]
  reviews                Review[]
  reviewReactions        ReviewReaction[]
  sessions               Session[]
  following              Follow[]             @relation("UserFollowing")
  followers              Follow[]             @relation("UserFollowers")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash, expiresAt])
  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthAttempt {
  id        String            @id @default(cuid())
  type      AuthAttemptType
  scope     AuthThrottleScope
  hash      String
  createdAt DateTime          @default(now())

  @@index([type, scope, hash, createdAt])
}

model ReadingListEntry {
  id            String   @id @default(cuid())
  userId        String
  provider      String   @default("mangadex")
  mangaId       String
  title         String
  altTitles     String[]
  description   String?
  status        String?
  year          Int?
  contentRating String?
  demographic   String?
  latestChapter String?
  languages     String[]
  tags          String[]
  coverImage    String?
  url           String
  progress      String?
  rating        Float?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, mangaId])
  @@index([userId, updatedAt])
}

model Review {
  id          String           @id @default(cuid())
  authorId    String
  provider    String
  mangaId     String
  rating      Int
  body        String?
  hasSpoilers Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  author      User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions   ReviewReaction[]

  @@unique([authorId, provider, mangaId])
  @@index([provider, mangaId])
  @@index([authorId])
  @@index([provider, mangaId, createdAt])
}

model ReviewReaction {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  type      String   // "thumbs_up" | "thumbs_down" | "funny" | "confusing" | "heart" | "angry"
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId, type])
  @@index([reviewId])
  @@index([userId])
}

// View counter for /manga/<id> pages. Powers a future "Hot on shujia"
// internal trending rail once the dataset is large enough to be useful
// (rule of thumb: ~1k+ active users). Until then, no UI reads from this
// — it's just data collection. Anonymous views get userId=null.
model MangaPageView {
  id        String   @id @default(cuid())
  provider  String
  mangaId   String
  userId    String?
  viewedAt  DateTime @default(now())

  @@index([mangaId, provider, viewedAt])
  @@index([viewedAt])
}

// Admin-set overrides for manga display titles. When MU/MD return a
// shorter or less-recognizable canonical title, an override here replaces
// it on detail pages and in serialized reading-list rows. Keyed by
// (provider, mangaId) so the same series can be overridden once and
// flow everywhere. Set via web/scripts/set-title-override.ts.
model MangaTitleOverride {
  id        String   @id @default(cuid())
  provider  String
  mangaId   String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, mangaId])
  @@index([provider, mangaId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model RegistrationVerification {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  name         String?
  passwordHash String
  tokenHash    String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

enum AuthAttemptType {
  LOGIN
  REGISTER
  FORGOT_PASSWORD
  RESET_PASSWORD
  VERIFY_EMAIL
}

enum AuthThrottleScope {
  IP
  IDENTIFIER
}
