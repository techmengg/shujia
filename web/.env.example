# ─────────────────────────────────────────────────────────────────────────────
# shujia — environment variables
#
# Copy this file to `.env` and fill in the values. None of the placeholders
# below are real credentials — they're shapes/examples to show the format.
#
# Quick start for local dev:
#   1. Run ./setup-local-db.sh (or .ps1 on Windows) to spin up a Docker
#      Postgres container at localhost:5433
#   2. cp .env.example .env
#   3. Replace placeholders below for any optional services you actually need
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# Postgres connection string. The default below matches what
# ./setup-local-db.sh creates locally — if you ran that, use it as-is.
DATABASE_URL="postgresql://postgres:devpassword@localhost:5433/shujia_dev?schema=public"

# Canonical site URL (used for absolute URLs in emails, OAuth redirects,
# share links, sitemap, structured data). Local dev: http://localhost:3000
APP_BASE_URL="http://localhost:3000"

# Public-facing site URL exposed to the browser (sitemap canonical, OG tags).
# In most setups this is the same as APP_BASE_URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── MangaUpdates API ─────────────────────────────────────────────────────────
# The catalog data source. Public REST API — no key required for reads.

MANGAUPDATES_API_BASE="https://api.mangaupdates.com/v1"
NEXT_PUBLIC_MANGAUPDATES_API_BASE="https://api.mangaupdates.com/v1"

# ── Google OAuth (optional — only needed for "Sign in with Google") ──────────
# Create a client at https://console.cloud.google.com/apis/credentials
# Add ${APP_BASE_URL}/api/auth/google/callback as an authorized redirect.

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email (optional — needed for verification, password reset emails) ────────
# Pick ONE provider. Resend is the default (preferred). SMTP is the fallback.

# Resend (https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="shujia <noreply@example.com>"

# SMTP fallback (used when RESEND_API_KEY is empty)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"

# ── Reddit proxy (recommended for production) ───────────────────────────────
# Powers the home "News" rail (r/manhwa [NEWS] posts) and the "Trending"
# rail (top weekly [DISC] threads from r/manga + r/manhwa). Reddit blocks
# unauthenticated requests from cloud IP ranges (Vercel/AWS/GCP), so on
# production these rails go empty unless traffic is routed through a
# Cloudflare Worker proxy (CF edge IPs aren't gated the same way).
#
# Setup: see tools/reddit-proxy/README.md — wrangler deploy gives you the
# URL, plus a shared secret you set via `wrangler secret put`.
#
# When unset, the code falls back to www.reddit.com directly (works fine
# from a developer laptop, fails on Vercel).

REDDIT_PROXY_URL=""
REDDIT_PROXY_SECRET=""

# ── Vercel Blob (optional — for avatar/banner uploads) ───────────────────────
# When the token is missing, uploads fall back to public/uploads/ on the
# local filesystem so you can test without cloud storage.

BLOB_READ_WRITE_TOKEN=""
# Public URL prefix where Blob serves your uploaded avatars from
# (e.g. https://abc123.public.blob.vercel-storage.com)
NEXT_PUBLIC_BLOB_BASE_URL=""
